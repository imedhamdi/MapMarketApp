const mongoose = require('mongoose');

const itemSchema = new mongoose.Schema({
  title: {
    type: String,
    required: true,
    maxlength: 100
  },
  description: {
    type: String,
    required: true,
    maxlength: 1000
  },
  price: {
    type: Number,
    required: true,
    min: 0
  },
  images: {
    type: [String], // chemins des fichiers via multer (ex: /uploads/items/xxx.jpg)
    default: []
  },
  category: {
    type: String,
    enum: [
      'immobilier',
      'vehicules',
      'emploi_services',
      'mode',
      'enfants',
      'electronique',
      'maison',
      'loisirs'
    ],
    required: true
  },
  condition: {
    type: String,
    enum: ['neuf', 'très bon état', 'bon état', 'moyen', 'à réparer'],
    required: true
  },
  coordinates: {
    lat: {
      type: Number,
      required: true
    },
    lng: {
      type: Number,
      required: true
    }
  },
  userId: {
    type: mongoose.Schema.Types.ObjectId,
    ref: 'User',
    required: true
  },
  createdAt: {
    type: Date,
    default: Date.now
  }
});

module.exports = mongoose.model('Item', itemSchema);
